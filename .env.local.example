# Supabase — from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Server-only. Used by /api routes that need to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe — from https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) locally, live keys (sk_live_...) in Vercel prod.
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret. `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# prints a whsec_... for local; the prod endpoint has its own.
STRIPE_WEBHOOK_SECRET=whsec_...

# Admin dashboard — server-only secret that gates write APIs under /api/admin/*.
# Generate any random string; the admin UI prompts for it.
ADMIN_SECRET=

# PostHog — silently no-op if either is unset. From https://eu.posthog.com (project settings).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Sentry — silently no-op if unset. SENTRY_DSN is server/edge, NEXT_PUBLIC_SENTRY_DSN is browser.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Site URL — used by absolute URL builders (Stripe redirects, OG, sitemap).
# Defaults to https://riffle.cc if unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
